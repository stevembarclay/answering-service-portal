# Supabase
NEXT_PUBLIC_SUPABASE_URL=           # Your Supabase project URL (from project settings → API)
NEXT_PUBLIC_SUPABASE_ANON_KEY=      # Your Supabase anon/public key (from project settings → API)
SUPABASE_SERVICE_ROLE_KEY=          # Your Supabase service role key (server-side only — required for client invite flow and seed script)

# App URL (used in invite emails — set to your production URL before provisioning real clients)
NEXT_PUBLIC_APP_URL=                # e.g. https://portal.yourcompany.com (defaults to http://localhost:3000 if unset)

# OpenAI / LLM provider (optional — AI coaches will be disabled if not set)
OPENAI_API_KEY=                     # API key for your LLM provider
OPENAI_MODEL=                       # Optional: model to use (defaults to gpt-4o-mini). e.g. gpt-4o, llama3.2
OPENAI_BASE_URL=                    # Optional: base URL for OpenAI-compatible providers.
                                    # Ollama (local):  http://localhost:11434/v1
                                    # Groq:            https://api.groq.com/openai/v1
                                    # Leave blank to use OpenAI directly (default).
AI_SERVICE_DESCRIPTION=             # Optional: one-phrase description of your service, used in AI coach prompts.
                                    # e.g. "24/7 medical answering service" or "legal intake service"

# Cal.com (optional — only needed if using the concierge booking flow in the setup wizard)
NEXT_PUBLIC_CAL_LINK=               # Your Cal.com link slug (e.g. your-org/onboarding)

# Support contact (shown in the dashboard AI assistant system prompt)
NEXT_PUBLIC_SUPPORT_EMAIL=          # e.g. support@yourcompany.com
NEXT_PUBLIC_SUPPORT_PHONE=          # e.g. +1-800-555-0000

# Deployment mode
# Set to 'true' for standalone / self-hosted deployments where you don't use per-module
# access gating. Auth is still enforced — only the enabled_modules database check is skipped.
STANDALONE_MODE=true

# Community edition flag — belt-and-suspenders for any managed-platform feature checks
COMMUNITY_EDITION=true

# CORS (optional — comma-separated list of allowed origins for the coach API routes)
ALLOWED_ORIGINS=http://localhost:3000

# Portal white-label branding
# PORTAL_NAME also sets the AI coach persona name.
PORTAL_NAME="Answering Service Portal"
PORTAL_LOGO_URL=""
PORTAL_BRAND_COLOR="#3b82f6"
PORTAL_SUPPORT_EMAIL="support@example.com"

# Transactional email (Resend — optional)
# Required to send branded invite emails when adding clients.
# If unset, Supabase Auth sends a default invite email instead.
RESEND_API_KEY=                     # Get your key at https://resend.com
RESEND_FROM_EMAIL=                  # Must be a domain verified in your Resend account.

# Vercel API (optional — required only for the custom domain registration feature)
# VERCEL_API_TOKEN:    Vercel API token with project write access
#   → Generate at: https://vercel.com/account/tokens
# VERCEL_PROJECT_ID:   Your Vercel project ID
#   → Found at: Vercel dashboard → Project Settings → General → Project ID
VERCEL_API_TOKEN=
VERCEL_PROJECT_ID=

# Cron secret — protects the /api/cron/ingest endpoint.
# Generate with: openssl rand -hex 32
CRON_SECRET=your-secret-here

# E2E / screenshot tests (optional — only needed when running Playwright tests)
# Defaults fall back to the demo seed credentials if unset.
TEST_CLIENT_EMAIL=demo@example.com
TEST_CLIENT_PASSWORD=demo-password-2026
TEST_OPERATOR_EMAIL=operator@example.com
TEST_OPERATOR_PASSWORD=operator-password-2026
